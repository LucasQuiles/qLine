{
  "SessionStart": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-session-start.py",
          "timeout": 5
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Read",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-pretool-read.py",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-posttool-write.py",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-posttool-bash.py",
          "timeout": 5
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-posttool-edit.py",
          "timeout": 5
        }
      ]
    }
  ],
  "PostToolUseFailure": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-posttool-failure.py",
          "timeout": 5
        }
      ]
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-prompt-submit.py",
          "timeout": 5
        }
      ]
    }
  ],
  "PreCompact": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-precompact.py",
          "timeout": 5
        }
      ]
    }
  ],
  "SubagentStop": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-subagent-stop.py",
          "timeout": 5
        }
      ]
    }
  ],
  "TaskCompleted": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-task-completed.py",
          "timeout": 5
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "matcher": ".*",
      "hooks": [
        {
          "type": "command",
          "command": "HOOKS_DIR/obs-session-end.py",
          "timeout": 5
        }
      ]
    }
  ]
}
